{
  "mcpServers": {
    "Browser": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@browsermcp/mcp@latest"
      ]
    },
    "Figma": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "mobile-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@mobilenext/mobile-mcp@0.2.3"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "storybook": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    }
  }
}
