layout {
    pane split_direction="vertical" {
        // Left: thin stacked sidebar. Starts with one opencode pane; any new
        // pane opened while focused here (Alt e / Alt d) appends to the stack
        // as a collapsed single-line tab that expands when selected.
        pane size="30%" stacked=true {
            pane command="opencode" close_on_exit=true
        }
        // Right: main editor workspace.
        pane command="nvim" focus=true size="70%" close_on_exit=true
    }
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
}
