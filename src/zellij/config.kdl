import "catppuccin.kdl"

keybinds clear-defaults=true {
    locked {
        bind "Alt ;" { SwitchToMode "normal"; }
    }
    shared_among "normal" "locked" {
        // Leader key: Alt Space enters the tmux (leader) mode for single-key commands
        bind "Alt Space" { SwitchToMode "tmux"; }

        bind "Alt w" {
            LaunchOrFocusPlugin "session-manager" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "locked"
        }
        bind "Alt r" { SwitchToMode "renametab"; TabNameInput 0; }
        bind "Alt n" { NewTab; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/update_tab_indexes.sh" { close_on_exit true; floating true; }; SwitchToMode "locked"; }
        bind "Alt x" { CloseTab; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/update_tab_indexes.sh" { close_on_exit true; floating true; }; SwitchToMode "locked"; }
        // bind "Alt i" { MoveTab "Left"; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/update_tab_indexes.sh" { close_on_exit true; floating true; }; SwitchToMode "locked"; }
        // bind "Alt o" { MoveTab "Right"; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/update_tab_indexes.sh" { close_on_exit true; floating true; }; SwitchToMode "locked"; }

        bind "Alt u" { MoveFocus "left"; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/open_ai_chat.sh" { close_on_exit true; in_place true; }; SwitchToMode "locked"; }
        bind "Alt i" { MoveFocus "left"; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/open_project_ai_chat.sh" { close_on_exit true; in_place true; }; SwitchToMode "locked"; }
        bind "Alt o" { Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/open_project_tool.sh" { close_on_exit true; in_place true; }; SwitchToMode "locked"; }
        bind "Alt p" { Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/open_project_nvim.sh" { close_on_exit true; in_place true; }; SwitchToMode "locked"; }

        bind "Alt c" { MoveFocus "left"; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/open_ai_commit.sh" { close_on_exit true; in_place true; }; SwitchToMode "locked"; }
        bind "Alt d" { NewPane "down"; SwitchToMode "locked"; }
        bind "Alt e" { NewPane "right"; SwitchToMode "locked"; }
        bind "Alt Enter" { ToggleFocusFullscreen; SwitchToMode "locked"; }
        bind "Alt q" { CloseFocus; SwitchToMode "locked"; }

        bind "Alt h" { MoveFocus "left"; }
        bind "Alt j" { MoveFocus "down"; }
        bind "Alt k" { MoveFocus "up"; }
        bind "Alt l" { MoveFocus "right"; }
        bind "Alt [" { MovePane "Up"; }
        bind "Alt '" { MovePane "Down"; }

        bind "Alt 1" { GoToTab 1; SwitchToMode "locked"; }
        bind "Alt 2" { GoToTab 2; SwitchToMode "locked"; }
        bind "Alt 3" { GoToTab 3; SwitchToMode "locked"; }
        bind "Alt 4" { GoToTab 4; SwitchToMode "locked"; }
        bind "Alt 5" { GoToTab 5; SwitchToMode "locked"; }
        bind "Alt 6" { GoToTab 6; SwitchToMode "locked"; }
        bind "Alt 7" { GoToTab 7; SwitchToMode "locked"; }
        bind "Alt 8" { GoToTab 8; SwitchToMode "locked"; }
        bind "Alt 9" { GoToTab 9; SwitchToMode "locked"; }
    }

    // Leader (tmux) mode — entered with Alt Space. Single-key commands; each
    // returns to locked mode. All Alt binds above are intentionally unchanged.
    tmux {
        // Panes
        bind "s" { NewPane "down"; SwitchToMode "locked"; }
        bind "v" { NewPane "right"; SwitchToMode "locked"; }
        bind "x" { CloseFocus; SwitchToMode "locked"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "locked"; }
        bind "f" { ToggleFloatingPanes; SwitchToMode "locked"; }
        bind "w" { TogglePaneEmbedOrFloating; SwitchToMode "locked"; }
        bind "h" { MoveFocus "left"; SwitchToMode "locked"; }
        bind "j" { MoveFocus "down"; SwitchToMode "locked"; }
        bind "k" { MoveFocus "up"; SwitchToMode "locked"; }
        bind "l" { MoveFocus "right"; SwitchToMode "locked"; }

        // Tabs
        bind "c" { NewTab; Run "zsh" "-c" "$HOME/Programming/JimmyTranDev/dotfiles/etc/scripts/src/zellij/update_tab_indexes.sh" { close_on_exit true; floating true; }; SwitchToMode "locked"; }
        bind "n" { GoToNextTab; SwitchToMode "locked"; }
        bind "b" { GoToPreviousTab; SwitchToMode "locked"; }
        bind "," { SwitchToMode "renametab"; TabNameInput 0; }
        bind "Tab" { ToggleTab; SwitchToMode "locked"; }

        // Session
        bind "d" { Detach; }
        bind "S" { ToggleActiveSyncTab; SwitchToMode "locked"; }

        // Leave leader mode
        bind "Esc" { SwitchToMode "locked"; }
        bind "q" { SwitchToMode "locked"; }
        bind "Ctrl c" { SwitchToMode "locked"; }
        bind "Alt Space" { SwitchToMode "locked"; }
    }
}

plugins {
    compact-bar location="zellij:compact-bar"
    configuration location="zellij:configuration"
    filepicker location="zellij:strider" {
        cwd "/"
    }
    plugin-manager location="zellij:plugin-manager"
    session-manager location="zellij:session-manager"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    tab-bar location="zellij:tab-bar"
    welcome-screen location="zellij:session-manager" {
        welcome_screen true
    }
}

load_plugins {
}

ui {
    pane_frames {
        rounded_corners true
        hide_session_name true
    }
    tab_bar {
        display_tab_index true
    }
}

theme "catppuccin-mocha"

default_mode "locked"

default_shell "zsh"

// Single-line compact status bar instead of the default two-line tab-bar + status-bar
default_layout "compact"

// Show the 1-cell pane frame so each pane title is visible — the zellij-pane-status plugin writes the opencode status into that title
pane_frames true
