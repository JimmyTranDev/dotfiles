{
  "$schema": "https://opencode.ai/config.json",
  // Disable auto-update prompts
  "autoupdate": false,
  // Default model: Claude Opus 4.8
  "model": "anthropic/claude-opus-4-8",
  // Additional markdown files injected as system instructions
  "instructions": [
    "AGENTS.md"
  ],
  // File edits denied; other actions allowed for autonomous operation
  "permission": {
    // Deny all file modifications — covers the edit, write, and patch tools.
    // Paste text into chat instead; the agent returns edited text inline.
    "edit": "deny",
    // Bash stays allowed, EXCEPT common file-mutating commands (deny rules last = last match wins).
    // Not airtight: shell redirection ('> file', '>> file') and interpreters (python/perl -i) can't be reliably pattern-blocked here.
    "bash": {
      "*": "allow",
      "sed -i*": "deny",
      "tee *": "deny",
      "cp *": "deny",
      "mv *": "deny",
      "rm *": "deny",
      "patch *": "deny",
      "truncate *": "deny",
      "dd *": "deny"
    },
    "skill": "allow",
    "webfetch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  // MCP servers — disabled by default, enable per-project as needed
  "mcp": {
    // Figma design-to-code via local proxy
    "Figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    // Browser automation for web scraping and testing
    "Browser": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    // iOS simulator and Android emulator interaction
    "mobile-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mobilenext/mobile-mcp@0.2.3"
      ],
      "enabled": false
    },
    // Playwright-based browser control with accessibility snapshots
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    // Storybook component docs and preview
    "storybook": {
      "type": "remote",
      "url": "http://localhost:6006/mcp",
      "enabled": false
    }
  }
}
