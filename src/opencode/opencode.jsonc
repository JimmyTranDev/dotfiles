{
  "$schema": "https://opencode.ai/config.json",
  // Disable auto-update prompts
  "autoupdate": false,
  // Additional markdown files injected as system instructions
  "instructions": [
    "AGENTS.md"
  ],
  // All permissions set to "allow" for unrestricted autonomous operation
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  // MCP servers — disabled by default, enable per-project as needed
  "mcp": {
    // Figma design-to-code via local proxy
    "Figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    },
    // Browser automation for web scraping and testing
    "Browser": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    // iOS simulator and Android emulator interaction
    "mobile-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mobilenext/mobile-mcp@0.2.3"
      ],
      "enabled": false
    },
    // Playwright-based browser control with accessibility snapshots
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    // Storybook component docs and preview
    "storybook": {
      "type": "remote",
      "url": "http://localhost:6006/mcp",
      "enabled": false
    }
  }
}
