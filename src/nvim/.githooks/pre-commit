#!/bin/zsh

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

GLOBAL_HOOK="$HOME/.config/git/hooks/pre-commit"
if [ -x "$GLOBAL_HOOK" ]; then
  "$GLOBAL_HOOK" || exit $?
fi

STAGED_LUA_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.lua' 2>/dev/null || true)

if [ -z "$STAGED_LUA_FILES" ]; then
  exit 0
fi

SELENE_BIN=""
if command -v selene &> /dev/null; then
  SELENE_BIN="selene"
elif [ -x "$HOME/.cargo/bin/selene" ]; then
  SELENE_BIN="$HOME/.cargo/bin/selene"
fi

if [ -z "$SELENE_BIN" ]; then
  echo -e "${YELLOW}selene not installed. Skipping Lua lint check.${NC}"
  echo -e "${YELLOW}Install with: cargo install selene${NC}"
  exit 0
fi

echo -e "${GREEN}Running selene on staged Lua files...${NC}"

ERRORS=0
while IFS= read -r file; do
  if [ -f "$file" ]; then
    $SELENE_BIN --display-style=quiet "$file" || ERRORS=1
  fi
done <<< "$STAGED_LUA_FILES"

if [ "$ERRORS" -ne 0 ]; then
  echo
  echo -e "${RED}selene found issues in staged Lua files.${NC}"
  echo -e "${YELLOW}Fix the issues above before committing.${NC}"
  echo -e "${YELLOW}Bypass with: git commit --no-verify${NC}"
  exit 1
fi

exit 0
