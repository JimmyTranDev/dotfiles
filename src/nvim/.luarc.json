{
  "diagnostics": {
    "globals": [
      "vim",
      "Snacks",
      "engage",
      "create_buffer_local_mappings"
    ],
    "disable": [
      "missing-fields"
    ]
  },
  "workspace": {
    "ignoreDir": [
      "yazi/plugins"
    ]
  },
  "format": {
    "enable": true,
    "defaultConfig": {
      "column_width": "1200"
    }
  }
}
