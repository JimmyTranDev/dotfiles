theme = catppuccin-mocha.conf
shell-integration = zsh
shell-integration-features = cursor,sudo,title
clipboard-read = allow
clipboard-write = allow
font-size = 16
confirm-close-surface = false
macos-titlebar-style = tabs
window-inherit-working-directory = true

keybind = clear

keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = shift+enter=text:\x1b\r

keybind = alt+n=new_tab
keybind = alt+q=close_surface
keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=goto_tab:9
keybind = alt+i=move_tab:-1
keybind = alt+o=move_tab:1

keybind = alt+d=new_split:down
keybind = alt+e=new_split:right
keybind = alt+x=close_surface
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:up
keybind = alt+down=goto_split:down

keybind = alt+r=prompt_tab_title
keybind = alt+f=toggle_split_zoom
keybind = alt+equal=equalize_splits
