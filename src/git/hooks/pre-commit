#!/bin/bash
set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# Resolve AI scripts directory
DOTFILES_DIR="$HOME/Programming/JimmyTranDev/dotfiles"
AI_SCRIPTS="$DOTFILES_DIR/etc/scripts/src/ai"

# Track results
declare -a RESULTS=()
FAILED=0

log_header() {
	local emoji="$1"
	local title="$2"
	echo
	echo -e "${BOLD}${BLUE}$emoji $title${NC}"
	echo -e "${BLUE}────────────────────────────────────${NC}"
}

log_pass() {
	echo -e "  ${GREEN}✓${NC} $1"
	RESULTS+=("${GREEN}✓${NC} $1")
}

log_fail() {
	echo -e "  ${RED}✗${NC} $1"
	RESULTS+=("${RED}✗${NC} $1")
	FAILED=1
}

log_skip() {
	echo -e "  ${YELLOW}⊘${NC} $1 (skipped)"
	RESULTS+=("${YELLOW}⊘${NC} $1 (skipped)")
}

# ─── 1. Gitleaks: Secret Detection ───────────────────────────────────────────

run_gitleaks() {
	log_header "🔐" "Secret Detection (gitleaks)"

	if ! command -v gitleaks &>/dev/null; then
		log_skip "gitleaks not installed (brew install gitleaks)"
		return
	fi

	if gitleaks protect --staged --no-banner 2>&1; then
		log_pass "No secrets detected"
	else
		log_fail "Secrets detected — remove them before committing"
	fi
}

# ─── 2. Lint ─────────────────────────────────────────────────────────────────

run_lint() {
	log_header "🔍" "Lint Check"

	if [[ ! -f "$AI_SCRIPTS/lint-check.sh" ]]; then
		log_skip "lint-check.sh not found"
		return
	fi

	# Detect if there's a linter configured
	if [[ ! -f "package.json" ]] && [[ ! -f "biome.json" ]] && [[ ! -f ".eslintrc.js" ]] && [[ ! -f "eslint.config.js" ]] && [[ ! -f "eslint.config.mjs" ]] && [[ ! -f "pom.xml" ]] && [[ ! -f "build.gradle" ]] && [[ ! -f "build.gradle.kts" ]]; then
		log_skip "No linter config detected"
		return
	fi

	if bash "$AI_SCRIPTS/lint-check.sh" . 2>&1; then
		log_pass "Lint passed"
	else
		log_fail "Lint errors found"
	fi
}

# ─── 3. Knip: Unused Code ────────────────────────────────────────────────────

run_knip() {
	log_header "🧹" "Unused Code (knip)"

	if [[ ! -f "package.json" ]]; then
		log_skip "No package.json — not a Node project"
		return
	fi

	if ! command -v npx &>/dev/null; then
		log_skip "npx not available"
		return
	fi

	if npx knip --no-progress 2>&1; then
		log_pass "No unused code detected"
	else
		log_fail "Unused code/exports found"
	fi
}

# ─── 4. Tests ─────────────────────────────────────────────────────────────────

run_tests() {
	log_header "🧪" "Tests"

	if [[ ! -f "$AI_SCRIPTS/run-tests.sh" ]]; then
		log_skip "run-tests.sh not found"
		return
	fi

	# Check if there's any test infrastructure
	if [[ ! -f "package.json" ]] && [[ ! -f "pom.xml" ]] && [[ ! -f "build.gradle" ]] && [[ ! -f "build.gradle.kts" ]] && [[ ! -f "Cargo.toml" ]]; then
		log_skip "No test runner detected"
		return
	fi

	if bash "$AI_SCRIPTS/run-tests.sh" . 2>&1; then
		log_pass "Tests passed"
	else
		log_fail "Tests failed"
	fi
}

# ─── Run All Checks ──────────────────────────────────────────────────────────

run_gitleaks
run_lint
run_knip
run_tests

# ─── Summary ──────────────────────────────────────────────────────────────────

echo
echo -e "${BOLD}────────────────────────────────────${NC}"
echo -e "${BOLD}Pre-commit Summary:${NC}"
for result in "${RESULTS[@]}"; do
	echo -e "  $result"
done
echo

if [[ "$FAILED" -eq 1 ]]; then
	echo -e "${RED}Commit blocked.${NC} Fix the issues above or bypass with:"
	echo -e "  ${GREEN}git commit --no-verify${NC}"
	echo
	exit 1
fi

echo -e "${GREEN}All checks passed.${NC}"
exit 0
